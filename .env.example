# Backend — copy to backend/.env

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/fleet?sslmode=require

# Auth
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRY_DAYS=90
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Trip validation
PHOTO_RETENTION_DAYS=365
OCR_KM_TOLERANCE=5
OCR_MAX_TRIP_KM=100
OCR_WARN_TRIP_KM=50
SPEED_WARN_KMH=110
SPEED_MAX_KMH=160
